# --- Base de données ---
# PRODUCTION (Vercel) : PostgreSQL. Collez ici l'URL de votre base
# (Vercel Postgres, Neon, Supabase…). Exemple :
DATABASE_URL="postgresql://user:password@host.neon.tech/lens?sslmode=require"
#
# DEV 100% LOCAL SANS POSTGRES (optionnel) : passez le provider du fichier
# prisma/schema.prisma sur "sqlite" puis utilisez :
# DATABASE_URL="file:./dev.db"

# --- Authentification (NextAuth / Auth.js) ---
# Générer un secret : openssl rand -base64 32
NEXTAUTH_SECRET="changeme-generez-un-secret-solide"
# En production, mettez l'URL finale de votre site Vercel :
NEXTAUTH_URL="http://localhost:3000"

# --- Espace Barber (admin) ---
# Laisser "false" pour l'accès libre (tests). Passer à "true" pour sécuriser.
ADMIN_AUTH_ENABLED="false"
# Identifiants du barbier (utilisés par le seed pour créer le compte admin).
ADMIN_EMAIL="barber@lensbarbershop.fr"
ADMIN_PASSWORD="ChangeMoi2026!"
